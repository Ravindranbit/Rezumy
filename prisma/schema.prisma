generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  // GitHub OAuth fields
  githubId          String?  @unique
  githubUsername     String?
  githubAccessToken  String?  // Encrypted with AES — see lib/crypto.ts

  profile         Profile?
  resumes         Resume[]
  githubRepos     GitHubRepo[]
  jobDescriptions JobDescription[]
}

model Profile {
  id       String @id @default(cuid())
  userId   String @unique
  phone    String @default("")
  location String @default("")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  education   Education[]
  experience  Experience[]
  skills      Skill[]
  projects    Project[]
}

model Education {
  id          String  @id @default(cuid())
  profileId   String
  institution String
  degree      String
  startDate   String
  endDate     String

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Experience {
  id          String @id @default(cuid())
  profileId   String
  company     String
  role        String
  description String @default("")
  startDate   String
  endDate     String

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Skill {
  id        String @id @default(cuid())
  profileId String
  name      String

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Project {
  id          String @id @default(cuid())
  profileId   String
  title       String
  description String @default("")
  techStack   String @default("")
  source      String @default("manual") // "manual" | "github"

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Resume {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("Untitled Resume")
  summary   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GitHubRepo {
  id          String  @id @default(cuid())
  userId      String
  repoId      Int     // GitHub's numeric repo ID
  name        String
  fullName    String  @default("")
  description String  @default("")
  language    String  @default("")
  topics      Json    @default("[]") // Array of topic strings
  url         String  @default("")
  stars       Int     @default(0)
  repoUpdatedAt String @default("")
  isSelected  Boolean @default(false)
  // Deep analysis results (v1 — kept for backward compatibility)
  analyzedSkills Json   @default("[]") // Enriched skills from file content analysis
  projectType    String @default("")   // e.g. "Full-Stack Web App", "ML Project", "CLI Tool"
  techStack      String @default("")   // Comma-separated canonical tech stack
  // v2: Structured project profile
  projectProfile  Json    @default("{}") // RepositoryProfile JSON
  qualityScore    Float   @default(0)    // 0–100 weighted quality score
  qualityGrade    String  @default("")   // A, B, C, D, F
  readmeSections  Json    @default("{}") // Parsed README sections
  verifiedTechs   Json    @default("[]") // VerifiedTechnology[] — only techs confirmed by source code
  activityMetrics Json    @default("{}") // ActivityMetrics JSON

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, repoId])
}

model JobDescription {
  id        String   @id @default(cuid())
  userId    String
  rawText   String   // Raw JD text pasted by user
  parsed    Json     @default("{}") // ParsedJobDescription JSON
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
